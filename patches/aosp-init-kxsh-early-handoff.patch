+bool PrepareKexecRuntime() {
+    constexpr const char* kKxshbinCandidates[] = {"/kxshbin", "/first_stage_ramdisk/kxshbin",
+                                                  nullptr};
+    const char* kxshbin = nullptr;
+    for (size_t i = 0; kKxshbinCandidates[i] != nullptr; i++) {
+        if (access(kKxshbinCandidates[i], X_OK) == 0) {
+            kxshbin = kKxshbinCandidates[i];
+            break;
+        }
+    }
+    if (kxshbin == nullptr) {
+        return false;
+    }
+
+    pid_t pid = fork();
+    if (pid < 0) {
+        PLOG(ERROR) << "fork() for " << kxshbin << " failed";
+        return false;
+    }
+    if (pid == 0) {
+        const char* args[] = {kxshbin, "--prepare", nullptr};
+        execv(kxshbin, const_cast<char**>(args));
+        PLOG(ERROR) << "execv(\"" << kxshbin << " --prepare\") failed";
+        _exit(127);
+    }
+
+    int status = 0;
+    if (waitpid(pid, &status, 0) != pid) {
+        PLOG(ERROR) << "waitpid() for " << kxshbin << " failed";
+        return false;
+    }
+    if (!WIFEXITED(status) || WEXITSTATUS(status) != 0) {
+        LOG(ERROR) << kxshbin << " --prepare failed: status=" << status;
+        return false;
+    }
+
+    LOG(INFO) << kxshbin << " --prepare completed";
+    return true;
+}
