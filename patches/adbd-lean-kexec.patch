@@ -16,6 +16,11 @@
 
 #define TRACE_TAG AUTH
 
+// Lean USB-only adbd build flag. Mirrors the #define in daemon/main.cpp; this
+// translation unit needs its own copy because auth.cpp compiles into libadbd, a
+// separate module, so main.cpp's #define is not visible here.
+#define LEAN_KEXEC_ADBD 1
+
 #include "sysdeps.h"
 
 #include <resolv.h>
@@ -246,12 +251,22 @@ void adbd_auth_init(void) {
     cb.key_authorized = adbd_auth_key_authorized;
     cb.key_removed = adbd_key_removed;
     auth_ctx = adbd_auth_new(&cb);
+#if defined(LEAN_KEXEC_ADBD)
+    // Lean USB-only adbd has no Android property service or framework socket, so
+    // both adbd_auth_init side-threads busy-spin a whole CPU each: the adb_wifi
+    // observer runs while(true){WaitForProperty(...)} (which never blocks without
+    // a property service) and adbd_auth_run() keeps retrying the framework
+    // connection. auth is forced off (see main.cpp), so skip both; auth_ctx
+    // itself is still created for any incidental references.
+    LOG(INFO) << "LEAN_KEXEC_ADBD: skipping adb_wifi observer and adbd_auth framework thread";
+#else
     adbd_wifi_init(auth_ctx);
     std::thread([]() {
         adb_thread_setname("adbd auth");
         adbd_auth_run(auth_ctx);
         LOG(FATAL) << "auth thread terminated";
     }).detach();
+#endif
 }
 
