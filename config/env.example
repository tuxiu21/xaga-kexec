# Copy to config/env for local overrides.
#
# The project keeps source trees under sources/ and all generated state under
# work/. Scripts source scripts/lib/env.sh and use these paths directly.

ROOT=/home/in/work/kernels
WORK_DIR=$ROOT/work
LOCAL_DIR=$ROOT/local

AK=$ROOT/sources/android-kernel
XIAOMI=$ROOT/sources/Xiaomi_Kernel_OpenSource
ONEPLUS_SRC=$ROOT/sources/android_kernel_5.10_oneplus_mt6895
AOSP_DIR=$ROOT/sources/android-12.1
KEXEC_TOOLS=$ROOT/sources/kexec-tools-2.0.28
GKI_BOOT_IMAGE=$LOCAL_DIR/boot-5.10.img

LOG_ROOT=$WORK_DIR/logs
OUTPUT_DIR=$WORK_DIR/output
VENDOR_DIR=$WORK_DIR/vendor
UNPACK_GKI_DIR=$WORK_DIR/unpack_gki
TMP_ROOT=$WORK_DIR/tmp
BLOCKTAG_BUILD_DIR=$WORK_DIR/tmp/blocktag_build
